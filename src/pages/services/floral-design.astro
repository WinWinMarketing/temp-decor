---
import ServicePageTemplate from '@/components/ServicePageTemplate.astro';

const faqs = [
  { question: 'Do you use real or silk flowers?', answer: 'We primarily work with fresh flowers for their natural beauty and fragrance. However, we also offer premium silk and preserved flower options for installations that need to last beyond a single event.' },
  { question: 'Can I request specific flowers?', answer: 'Of course. We work with your preferences and seasonal availability to source the perfect blooms. If a specific variety is out of season, we will suggest beautiful alternatives that achieve the same look.' },
  { question: 'How far in advance should I order?', answer: 'For weddings and large events, we recommend 3-6 months advance booking. For smaller arrangements and home floral subscriptions, 1-2 weeks notice is typically sufficient.' },
  { question: 'Do you offer floral subscriptions for homes or offices?', answer: 'Yes. Our weekly and bi-weekly floral subscription service delivers fresh, seasonally curated arrangements to homes and offices across the GTA.' },
];
---

<ServicePageTemplate
  title="Floral Design"
  description="Custom floral design services in Toronto — bridal bouquets, wedding centerpieces, floral installations, and seasonal arrangements crafted with the freshest blooms."
