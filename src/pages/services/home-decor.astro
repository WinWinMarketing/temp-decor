---
import ServicePageTemplate from '@/components/ServicePageTemplate.astro';

const faqs = [
  { question: 'What rooms do you work with?', answer: 'We style all living spaces — living rooms, dining rooms, bedrooms, home offices, and outdoor areas. We also offer whole-home packages for complete transformations.' },
  { question: 'Do I need to buy new furniture?', answer: 'Not necessarily. We often work with existing furniture and supplement with new accent pieces, art, textiles, and accessories to completely refresh a space.' },
  { question: 'How long does a typical home project take?', answer: 'A single room refresh typically takes 2-4 weeks from consultation to reveal. Whole-home projects range from 6-12 weeks depending on scope and sourcing needs.' },
  { question: 'Do you offer virtual consultations?', answer: 'Yes. We offer virtual consultations for clients outside the GTA or for initial discussions. In-person visits are recommended for accurate measurements and material assessment.' },
];
---

<ServicePageTemplate
  title="Home Decor"
  description="Transform your living spaces with luxury home decor and interior styling services in Toronto — curated design that blends comfort and elegance."
  heroImage="https://images.unsplash.com/photo-1616486338812-3dadae4b4ace?w=1920&q=80"
  intro="Your home should be a reflection of who you are — a sanctuary that combines comfort, beauty, and personal expression. Our home decor services bring curated luxury into every room, creating spaces that feel both elevated and deeply inviting."
  features={[
    'Full room styling and interior design',
    'Furniture selection and arrangement',
    'Art curation and wall styling',
    'Textile and soft furnishing selection',
    'Seasonal decor and holiday styling',
    'Staging for real estate listings',
    'Outdoor living space design',
    'Custom shelving and display curation',
  ]}
  galleryImages={[
    'https://images.unsplash.com/photo-1616486338812-3dadae4b4ace?w=900&q=80',
    'https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?w=600&q=80',
    'https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?w=600&q=80',
    'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=600&q=80',
  ]}
  faqs={faqs}
/>
