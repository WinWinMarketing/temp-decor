---
import ServicePageTemplate from '@/components/ServicePageTemplate.astro';

const faqs = [
  { question: 'How far in advance should I book?', answer: 'We recommend booking 6-12 months in advance for weddings, especially during peak season (May-October). However, we occasionally accommodate shorter timelines depending on availability.' },
  { question: 'Do you provide a mockup before the event?', answer: 'Absolutely. After our initial consultation, we create detailed mood boards, 3D renderings, and sample layouts so you can visualize exactly how your venue will look.' },
  { question: 'Can you work with my venue\'s restrictions?', answer: 'Yes, we have experience with venues across the GTA and understand common restrictions around candles, hanging installations, and setup times. We always coordinate directly with your venue.' },
  { question: 'Do you offer day-of coordination?', answer: 'While our primary focus is design and decor, we coordinate all setup and teardown on the day of your event. For full day-of coordination, we can recommend trusted partners.' },
  { question: 'What is the typical investment for wedding decor?', answer: 'Our wedding decor packages typically range from $3,000 to $25,000+ depending on guest count, venue size, and design complexity. We offer customized quotes after our initial consultation.' },
];
---

<ServicePageTemplate
  title="Wedding Decor"
  description="Luxury wedding decoration services in Toronto — floral arches, tablescapes, centerpieces, and complete venue transformations."
  heroImage="https://images.unsplash.com/photo-1519225421980-715cb0215aed?w=1920&q=80"
  intro="Your wedding day deserves nothing less than extraordinary. We specialize in creating immersive wedding environments — from the ceremony aisle to the last dance — where every detail reflects your love story and leaves your guests in awe."
  features={[
    'Custom floral arches and ceremony backdrops',
    'Luxury tablescapes with fine linens and glassware',
    'Centerpiece design and installation',
    'Venue-wide lighting design and uplighting',
    'Aisle and entrance decor',
    'Sweetheart table and head table styling',
    'Ceiling installations and drapery',
    'Complete setup and teardown service',
  ]}
  galleryImages={[
    'https://images.unsplash.com/photo-1519225421980-715cb0215aed?w=900&q=80',
    'https://images.unsplash.com/photo-1519167758481-83f550bb49b3?w=600&q=80',
    'https://images.unsplash.com/photo-1465495976277-4387d4b0b4c6?w=600&q=80',
    'https://images.unsplash.com/photo-1478146059778-26028b07395a?w=600&q=80',
  ]}
  faqs={faqs}
/>
