---
import ServicePageTemplate from '@/components/ServicePageTemplate.astro';

const faqs = [
  { question: 'How far in advance should I book birthday party decor?', answer: 'We recommend booking at least 2-4 weeks in advance for standard party setups. For themed parties with custom props and signage, 4-6 weeks is ideal to allow time for design and production.' },
  { question: 'What themed party options do you offer?', answer: 'We can create any theme you envision — from popular characters like Sesame Street, Cocomelon, and Disney to custom themes like safari, nautical, circus, and more. Share your ideas and we will bring them to life.' },
  { question: 'Do you decorate for all ages?', answer: 'Absolutely. We specialize in first birthdays and kids\' parties, but we also style milestone celebrations for adults — 30th, 40th, 50th birthdays, sweet sixteens, and more.' },
  { question: 'How long does setup typically take?', answer: 'Setup time varies by complexity. A standard party setup takes 1-2 hours, while larger themed installations with custom props and backdrops may take 3-4 hours. We always arrive well before your event starts.' },
  { question: 'Do you provide takedown after the event?', answer: 'Yes, we offer full takedown and cleanup of all our decor elements after your event ends. This is included in most of our party packages.' },
];
---

<ServicePageTemplate
  title="Birthday & Party Decor"
  description="Custom birthday party decorations in Toronto and the GTA — themed parties, first birthday setups, milestone celebrations, props, signage, and balloon decor by Sai Decoration."
  heroImage="https://images.unsplash.com/photo-1530103862676-de8c9debad1d?w=1920&q=80"
  intro="Every birthday deserves to be unforgettable. We create magical party environments with custom themes, handcrafted props, eye-catching backdrops, and thoughtful details that make your celebration truly special — from first birthdays to milestone parties and everything in between."
  features={[
    'Themed party decoration and styling',
    'First birthday setups and smash cake scenes',
    'Milestone birthday styling (Sweet 16, 30th, 50th, etc.)',
    'Custom props and signage design',
    'Cutout design and printing',
    'Themed table settings and centrepieces',
    'Candy and dessert table styling',
    'Backdrop design and installation',
  ]}
  galleryImages={[
    'https://images.unsplash.com/photo-1530103862676-de8c9debad1d?w=900&q=80',
    'https://images.unsplash.com/photo-1464349095431-e9a21285b5f3?w=600&q=80',
    'https://images.unsplash.com/photo-1513151233558-d860c5398176?w=600&q=80',
    'https://images.unsplash.com/photo-1511795409834-ef04bbd61622?w=600&q=80',
  ]}
  faqs={faqs}
/>
