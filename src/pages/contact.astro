---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContactForm from '@/components/ContactForm.tsx';
---

<BaseLayout
  title="Contact | Sai Decoration"
  description="Get in touch with Sai Decoration for a free consultation. Luxury wedding decor, home styling, and event design in Toronto and the GTA."
>
  <section class="pt-32 pb-12 bg-ivory">
    <div class="container text-center">
      <p class="section-label mb-4" data-animate="fade-up">Get in Touch</p>
      <h1 class="font-heading text-h1 text-charcoal mb-6" data-animate="fade-up">
        Connect with Us
      </h1>
      <p class="text-lead text-warm-gray max-w-2xl mx-auto" data-animate="fade-up">
        Ready to bring your vision to life? Fill out the form below or reach out directly —
        we respond to every inquiry within 24 hours.
      </p>
    </div>
  </section>

  <section class="py-12 pb-24 bg-ivory">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
        <div class="lg:col-span-3" data-animate="fade-up">
          <ContactForm client:visible />
        </div>

        <div class="lg:col-span-2 space-y-10" data-animate="fade-up">
          <div>
            <h3 class="font-heading text-h4 text-charcoal mb-4">Contact Info</h3>
            <ul class="space-y-4 text-warm-gray">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gold mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
                <div>
                  <p class="text-sm font-medium text-charcoal">Phone</p>
                  <a href="tel:+14161234567" class="text-sm hover:text-gold transition-colors">+1 (416) 123-4567</a>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gold mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
                <div>
                  <p class="text-sm font-medium text-charcoal">Email</p>
                  <a href="mailto:hello@saidecoration.com" class="text-sm hover:text-gold transition-colors">hello@saidecoration.com</a>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gold mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
                <div>
                  <p class="text-sm font-medium text-charcoal">Location</p>
                  <p class="text-sm">Toronto, Ontario, Canada</p>
                  <p class="text-xs text-warm-gray mt-1">Serving the GTA and surrounding areas</p>
                </div>
              </li>
            </ul>
          </div>

          <div>
            <h3 class="font-heading text-h4 text-charcoal mb-4">Hours</h3>
            <ul class="space-y-2 text-sm text-warm-gray">
              <li class="flex justify-between">
                <span>Monday — Friday</span>
                <span class="text-charcoal">9:00 AM — 6:00 PM</span>
              </li>
              <li class="flex justify-between">
                <span>Saturday</span>
                <span class="text-charcoal">10:00 AM — 4:00 PM</span>
              </li>
              <li class="flex justify-between">
                <span>Sunday</span>
                <span class="text-charcoal">By Appointment</span>
              </li>
            </ul>
          </div>

          <div>
            <h3 class="font-heading text-h4 text-charcoal mb-4">Follow Us</h3>
            <div class="flex gap-3">
              <a href="https://www.instagram.com/sai_decoration" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-10 h-10 rounded-full border border-warm-gray-light flex items-center justify-center text-warm-gray hover:border-gold hover:text-gold transition-all duration-300" data-magnetic>
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </a>
              <a href="#" aria-label="Facebook" class="w-10 h-10 rounded-full border border-warm-gray-light flex items-center justify-center text-warm-gray hover:border-gold hover:text-gold transition-all duration-300" data-magnetic>
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
              <a href="#" aria-label="Pinterest" class="w-10 h-10 rounded-full border border-warm-gray-light flex items-center justify-center text-warm-gray hover:border-gold hover:text-gold transition-all duration-300" data-magnetic>
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { initSectionAnimations } from '@/scripts/animations';
    document.addEventListener('astro:page-load', () => initSectionAnimations());
  </script>
</BaseLayout>
