---
import BaseLayout from '@/layouts/BaseLayout.astro';
import GalleryGrid from '@/components/GalleryGrid.tsx';
import { getAllProjects, getProjectBySlug } from '@/scripts/projects';

export function getStaticPaths() {
  const projects = getAllProjects();
  return projects.map((project) => ({
    params: { slug: project.slug },
  }));
}

const { slug } = Astro.params;
const project = getProjectBySlug(slug!);

if (!project) {
  return Astro.redirect('/portfolio');
}

const allProjects = getAllProjects();
const currentIndex = allProjects.findIndex((p) => p.slug === slug);
const nextProject = allProjects[(currentIndex + 1) % allProjects.length];

const galleryImages = project.images.map((src, i) => ({
  src,
  alt: `${project.title} - Image ${i + 1}`,
}));
---

<BaseLayout
  title={`${project.title} | Sai Decoration`}
  description={project.excerpt}
>
  <section class="relative h-[70vh] min-h-[500px] flex items-end overflow-hidden">
    <img
      src={project.coverImage}
      alt={project.title}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-charcoal/80 via-charcoal/30 to-transparent"></div>
    <div class="container relative z-10 pb-12 lg:pb-16">
      <span class="inline-block px-3 py-1 text-[0.65rem] uppercase tracking-[0.2em] bg-gold/80 text-ivory rounded-full mb-4 font-body font-medium">
        {project.category}
      </span>
      <h1 class="font-heading text-h1 text-ivory mb-3">{project.title}</h1>
      <p class="text-ivory/60 font-body text-sm">
        {project.location} &middot; {new Date(project.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
      </p>
    </div>
  </section>

  <section class="py-16 lg:py-24 bg-ivory">
    <div class="container-narrow">
      <div class="prose prose-lg max-w-none">
        {project.body.split('\n\n').map((paragraph) => (
          <p class="text-warm-gray leading-relaxed mb-6 font-body text-body" data-animate="fade-up">
            {paragraph}
          </p>
        ))}
      </div>
    </div>
  </section>

  <section class="py-12 pb-24 bg-ivory">
    <div class="container">
      <h2 class="font-heading text-h2 text-charcoal text-center mb-12" data-animate="fade-up">
        Project Gallery
      </h2>
      <GalleryGrid client:visible images={galleryImages} columns={3} />
    </div>
  </section>

  <section class="py-16 bg-cream">
    <div class="container flex flex-col sm:flex-row items-center justify-between gap-8">
      <a
        href="/portfolio"
        class="inline-flex items-center gap-2 text-sm uppercase tracking-[0.12em] font-medium text-warm-gray
               hover:text-charcoal transition-colors duration-300 group"
      >
        <svg class="w-4 h-4 transition-transform duration-300 group-hover:-translate-x-1" fill="none" viewBox="0 0 14 14" stroke="currentColor" stroke-width="1.5">
          <path d="M13 7H1M6 2L1 7l5 5" />
        </svg>
        All Projects
      </a>
      <a
        href={`/portfolio/${nextProject.slug}`}
        class="inline-flex items-center gap-3 group"
      >
        <div class="text-right">
          <span class="block text-xs uppercase tracking-[0.15em] text-warm-gray font-body">Next Project</span>
          <span class="block font-heading text-h4 text-charcoal group-hover:text-gold transition-colors duration-300">{nextProject.title}</span>
        </div>
        <svg class="w-5 h-5 text-gold transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 14 14" stroke="currentColor" stroke-width="1.5">
          <path d="M1 7h12M8 2l5 5-5 5" />
        </svg>
      </a>
    </div>
  </section>

  <section class="py-20 relative overflow-hidden">
    <div class="absolute inset-0 bg-charcoal/80">
    </div>
    <div class="container relative z-10 text-center">
      <h2 class="font-heading text-h2 text-ivory mb-4">Love What You See?</h2>
      <p class="text-ivory/60 mb-8 font-body">Let's create something just as beautiful for your next event.</p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 px-8 py-3.5 bg-gold text-ivory text-sm uppercase tracking-[0.15em] font-body font-medium rounded-sm hover:bg-gold-light transition-all duration-500"
      >
        Get a Quote
      </a>
    </div>
  </section>

  <script>
    import { initSectionAnimations } from '@/scripts/animations';
    document.addEventListener('astro:page-load', () => initSectionAnimations());
  </script>
</BaseLayout>
