---
---
<section class="py-20 lg:py-28 bg-ivory" id="intro">
  <div class="container">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div>
        <p class="section-label mb-4" data-animate="fade-up">Wedding Decor Is Our Passion</p>
        <h2 class="font-heading text-h1 text-charcoal mb-6" data-animate="fade-up">
          Complete Wedding Decoration Services at Your Fingertips
        </h2>
        <p class="text-lead text-warm-gray leading-relaxed mb-4" data-animate="fade-up">
          Temp Decor provides enchanting and exquisite wedding decor services
          tailored to your unique style and vision. Trust our expert team to create
          a magical ambiance and turn your dream wedding into a reality.
        </p>
        <p class="text-warm-gray leading-relaxed mb-8" data-animate="fade-up">
          Choose us for unforgettable wedding decor — we'll bring your vision to life
          with expertly executed details, leaving you stress-free on your special day.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 px-8 py-3.5
                 bg-gold text-ivory text-sm uppercase tracking-[0.15em] font-body font-medium
                 rounded-sm transition-all duration-500 hover:bg-gold-light hover:shadow-lg group"
          data-animate="fade-up"
        >
          <span>Get a Quote</span>
          <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 14 14" stroke="currentColor" stroke-width="1.5">
            <path d="M1 7h12M8 2l5 5-5 5" />
          </svg>
        </a>
      </div>
      <div class="grid grid-cols-2 gap-4" data-animate="fade-up">
        <div class="aspect-[3/4] overflow-hidden rounded-2xl">
          <img
            src="https://images.unsplash.com/photo-1520854221256-17451cc331bf?w=600&q=80"
            alt="Bride with elegant bouquet"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="aspect-[3/4] overflow-hidden rounded-2xl mt-8">
          <img
            src="https://images.unsplash.com/photo-1522673607200-164d1b6ce486?w=600&q=80"
            alt="Elegant wedding reception table"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>
