---
const base = '/temp-decor';
---
<section class="py-20 lg:py-28 bg-ivory" id="intro">
  <div class="container">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div>
        <p class="section-label mb-4" data-animate="fade-up">Decoration Is Our Passion</p>
        <h2 class="font-heading text-h1 text-charcoal mb-6" data-animate="fade-up">
          Beautiful Decor for Every Celebration
        </h2>
        <p class="text-lead text-warm-gray leading-relaxed mb-4" data-animate="fade-up">
          Sai Decoration Inc. brings your celebrations to life with stunning event decor —
          from dream weddings and themed birthday parties to elegant balloon installations
          and cultural celebrations. Every detail is crafted to perfection.
        </p>
        <p class="text-warm-gray leading-relaxed mb-8" data-animate="fade-up">
          Whether it's your child's first birthday, a milestone anniversary, or the wedding
          of your dreams — our team creates unforgettable environments with custom props,
          balloon garlands, and expertly styled spaces across the GTA.
        </p>
        <a
          href={`${base}/contact`}
          class="inline-flex items-center justify-center gap-2 px-8 py-3.5
                 bg-gold text-ivory text-sm uppercase tracking-[0.15em] font-body font-medium
                 rounded-sm transition-all duration-500 hover:bg-gold-light hover:shadow-lg group"
          data-animate="fade-up"
        >
          <span>Get a Quote</span>
          <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 14 14" stroke="currentColor" stroke-width="1.5">
            <path d="M1 7h12M8 2l5 5-5 5" />
          </svg>
        </a>
      </div>
      <div class="grid grid-cols-2 gap-4" data-animate="fade-up">
        <div class="aspect-[3/4] overflow-hidden rounded-2xl">
          <img
            src="https://images.unsplash.com/photo-1530103862676-de8c9debad1d?w=600&q=80"
            alt="Colourful birthday party celebration"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="aspect-[3/4] overflow-hidden rounded-2xl mt-8">
          <img
            src="https://images.unsplash.com/photo-1519167758481-83f550bb49b3?w=600&q=80"
            alt="Stunning wedding reception decor"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>
