---
const projects = [
  {
    title: 'The Grand Rosewood Reception',
    category: 'Wedding',
    image: 'https://images.unsplash.com/photo-1519167758481-83f550bb49b3?w=900&q=80',
    href: '/portfolio/grand-rosewood-reception',
  },
  {
    title: 'Modern Minimalist Home',
    category: 'Home Decor',
    image: 'https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?w=900&q=80',
    href: '/portfolio/modern-minimalist-home',
  },
  {
    title: 'Enchanted Garden Ceremony',
    category: 'Wedding',
    image: 'https://images.unsplash.com/photo-1465495976277-4387d4b0b4c6?w=900&q=80',
    href: '/portfolio/enchanted-garden-ceremony',
  },
  {
    title: 'Golden Anniversary Gala',
    category: 'Event',
    image: 'https://images.unsplash.com/photo-1511795409834-ef04bbd61622?w=900&q=80',
    href: '/portfolio/golden-anniversary-gala',
  },
];
---

<section class="py-24 lg:py-32 bg-cream" id="featured-work">
  <div class="container">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between mb-16 gap-6">
      <div>
        <p class="section-label mb-4" data-animate="fade-up">Your Design</p>
        <h2 class="font-heading text-h1 text-charcoal" data-animate="fade-up">
          Selected Projects
        </h2>
      </div>
      <a
        href="/portfolio"
        class="inline-flex items-center gap-2 text-sm uppercase tracking-[0.12em] font-medium text-gold
               hover:text-gold-dark transition-colors duration-300 group"
        data-animate="fade-up"
      >
        View All Projects
        <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 14 14" stroke="currentColor" stroke-width="1.5">
          <path d="M1 7h12M8 2l5 5-5 5" />
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {projects.map((project) => (
        <a
          href={project.href}
          class="group relative overflow-hidden rounded-2xl block aspect-[4/3]"
          data-animate="fade-up"
        >
          <img
            src={project.image}
            alt={project.title}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-charcoal/70 via-charcoal/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6 lg:p-8">
            <span class="inline-block px-3 py-1 text-[0.65rem] uppercase tracking-[0.2em] bg-gold/80 text-ivory rounded-full mb-3 font-body font-medium">
              {project.category}
            </span>
            <h3 class="font-heading text-h3 text-ivory group-hover:text-gold-light transition-colors duration-300">
              {project.title}
            </h3>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
