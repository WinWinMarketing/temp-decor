---
const base = '/temp-decor';
const navLinks = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/services`, label: 'Decor Services' },
  { href: `${base}/portfolio`, label: 'Your Design' },
  { href: `${base}/about`, label: 'Our Company' },
  { href: `${base}/contact`, label: 'Contact Us' },
];
const navLeft = navLinks.slice(0, 3);
const navRight = navLinks.slice(3);
const navLinkClass =
  'relative text-sm uppercase tracking-[0.12em] text-white/90 font-body font-medium whitespace-nowrap hover:text-white transition-colors duration-300 py-0.5 after:content-[\'\'] after:absolute after:bottom-0 after:left-0 after:w-0 after:h-px after:bg-gold after:transition-all after:duration-500 hover:after:w-full';
---

<header
  class="site-header fixed top-0 inset-x-0 z-50 overflow-visible border-0 transition-transform duration-500 ease-out motion-reduce:transition-none"
  id="site-header"
>
  <div
    class="relative z-[1] container grid grid-cols-[1fr_auto_1fr] items-start gap-x-4 pt-1.5 pb-3 lg:gap-x-8 lg:pt-2 lg:pb-3.5 xl:gap-x-12"
  >
    <div class="col-start-1 row-start-1 flex items-start justify-end min-w-0">
      <nav class="hidden lg:flex items-center justify-end gap-5 xl:gap-8" aria-label="Primary sections">
        {navLeft.map((link) => (
          <a href={link.href} class={navLinkClass}>
            {link.label}
          </a>
        ))}
      </nav>
    </div>

    <a
      href="/temp-decor/"
      class="col-start-2 row-start-1 justify-self-center self-start shrink-0 group relative z-[2] mt-4 px-2 pb-1 sm:mt-5 lg:mt-6"
    >
      <img
        src="/temp-decor/logo.png"
        alt="Sai Decoration"
        class="h-[48px] w-auto lg:h-[54px] transition-transform duration-300 group-hover:scale-[1.02]"
        loading="eager"
      />
    </a>

    <div class="col-start-3 row-start-1 flex items-start justify-end gap-3 min-w-0 lg:justify-start lg:gap-5 xl:gap-8">
      <nav class="hidden lg:flex items-center gap-6 xl:gap-8" aria-label="Company and contact">
        {navRight.map((link) => (
          <a href={link.href} class={navLinkClass}>
            {link.label}
          </a>
        ))}
      </nav>
      <a
        href="/temp-decor/contact"
        class="relative hidden lg:inline-flex items-center gap-2 px-4 py-1.5 xl:px-5 text-sm uppercase tracking-[0.12em]
               font-body font-medium border border-white/35 rounded-full text-white shrink-0
               overflow-hidden transition-colors duration-500 hover:text-ivory hover:border-gold
               group"
      >
        <span class="relative z-10">Get a Quote</span>
        <svg class="relative z-10 w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 14 14" stroke="currentColor" stroke-width="1.5">
          <path d="M1 7h12M8 2l5 5-5 5" />
        </svg>
        <span class="absolute inset-0 bg-gold scale-x-0 origin-left transition-transform duration-500 group-hover:scale-x-100"></span>
      </a>
      <button
        class="lg:hidden flex flex-col gap-1.5 p-2 -mr-2 mt-0.5"
        id="mobile-toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span class="block w-6 h-px bg-white transition-all duration-300 origin-center" id="hamburger-top"></span>
        <span class="block w-6 h-px bg-white transition-all duration-300" id="hamburger-mid"></span>
        <span class="block w-4 h-px bg-white transition-all duration-300 origin-center" id="hamburger-bot"></span>
      </button>
    </div>
  </div>

  <div
    class="fixed inset-0 z-[3] bg-black/95 backdrop-blur-md flex flex-col items-center justify-center
           opacity-0 pointer-events-none transition-opacity duration-500"
    id="mobile-menu"
  >
    <nav class="flex flex-col items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="font-heading text-h2 text-white hover:text-gold transition-colors duration-300"
        >
          {link.label}
        </a>
      ))}
    </nav>
    <div class="mt-12">
      <a
        href="/temp-decor/contact"
        class="inline-flex items-center gap-2 px-8 py-3 bg-gold text-ivory text-sm uppercase
               tracking-[0.15em] font-body font-medium rounded-full"
      >
        Get a Quote
      </a>
    </div>
  </div>
</header>

<style is:global>
  /* Thin full-width bar */
  .site-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3rem;
    z-index: 0;
    pointer-events: none;
    background-color: rgb(0 0 0 / 0.75);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgb(255 255 255 / 0.1);
  }

  /* Center tab behind logo: square-ish panel, rounded bottom only */
  .site-header::after {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 10.75rem;
    height: 6.25rem;
    z-index: 0;
    pointer-events: none;
    background-color: rgb(0 0 0 / 0.75);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 0 0 1rem 1rem;
    border: 1px solid rgb(255 255 255 / 0.1);
    border-top: none;
    box-shadow: inset 0 -1px 0 0 rgb(255 255 255 / 0.06);
  }

  @media (min-width: 1024px) {
    .site-header::before {
      height: 3.125rem;
    }

    .site-header::after {
      width: 12.5rem;
      height: 6.75rem;
      border-radius: 0 0 1.125rem 1.125rem;
    }
  }
</style>

<script>
  /** @type {(() => void) | undefined} */
  let headerScrollHandler;

  function initHeader() {
    const header = document.getElementById('site-header');
    const toggle = document.getElementById('mobile-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const hamburgerTop = document.getElementById('hamburger-top');
    const hamburgerMid = document.getElementById('hamburger-mid');
    const hamburgerBot = document.getElementById('hamburger-bot');

    if (!header || !toggle || !mobileMenu) return;

    if (headerScrollHandler) {
      window.removeEventListener('scroll', headerScrollHandler);
    }

    const w = window;
    if (w.__headerUiAbort) w.__headerUiAbort.abort();
    w.__headerUiAbort = new AbortController();
    const uiSignal = w.__headerUiAbort.signal;

    let lastScroll = window.scrollY;
    let isMenuOpen = false;
    header.style.transform = 'translateY(0)';

    headerScrollHandler = () => {
      if (isMenuOpen) return;
      const currentScroll = window.scrollY;

      if (currentScroll > lastScroll && currentScroll > 200) {
        header.style.transform = 'translateY(-100%)';
      } else {
        header.style.transform = 'translateY(0)';
      }
      lastScroll = currentScroll;
    };

    window.addEventListener('scroll', headerScrollHandler, { passive: true });

    toggle.addEventListener('click', () => {
      isMenuOpen = !isMenuOpen;
      toggle.setAttribute('aria-expanded', String(isMenuOpen));

      if (isMenuOpen) {
        mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
        mobileMenu.classList.add('opacity-100', 'pointer-events-auto');
        hamburgerTop?.classList.add('rotate-45', 'translate-y-[4px]');
        hamburgerMid?.classList.add('opacity-0');
        hamburgerBot?.classList.add('-rotate-45', '-translate-y-[4px]', 'w-6');
        document.body.style.overflow = 'hidden';
      } else {
        mobileMenu.classList.add('opacity-0', 'pointer-events-none');
        mobileMenu.classList.remove('opacity-100', 'pointer-events-auto');
        hamburgerTop?.classList.remove('rotate-45', 'translate-y-[4px]');
        hamburgerMid?.classList.remove('opacity-0');
        hamburgerBot?.classList.remove('-rotate-45', '-translate-y-[4px]', 'w-6');
        document.body.style.overflow = '';
      }
    }, { signal: uiSignal });

    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        isMenuOpen = false;
        mobileMenu.classList.add('opacity-0', 'pointer-events-none');
        mobileMenu.classList.remove('opacity-100', 'pointer-events-auto');
        hamburgerTop?.classList.remove('rotate-45', 'translate-y-[4px]');
        hamburgerMid?.classList.remove('opacity-0');
        hamburgerBot?.classList.remove('-rotate-45', '-translate-y-[4px]', 'w-6');
        document.body.style.overflow = '';
      }, { signal: uiSignal });
    });
  }

  document.addEventListener('astro:page-load', initHeader);
</script>
