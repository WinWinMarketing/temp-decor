---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Decor Services' },
  { href: '/portfolio', label: 'Your Design' },
  { href: '/about', label: 'Our Company' },
  { href: '/contact', label: 'Contact Us' },
];
---

<header
  class="fixed top-0 inset-x-0 z-50 transition-all duration-500 bg-ivory/75 backdrop-blur-lg border-b border-warm-gray-light/20"
  id="site-header"
>
  <div class="container flex items-center justify-between h-18 lg:h-22">
    <a href="/" class="block group">
      <img src="/temp-decor/logo.png" alt="Sai Decoration" class="h-8 lg:h-10 w-auto" />
    </a>

    <nav class="hidden lg:flex items-center gap-8" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="relative text-sm uppercase tracking-[0.12em] text-warm-gray font-body font-medium
                 hover:text-charcoal transition-colors duration-300 py-2
                 after:content-[''] after:absolute after:bottom-0 after:left-0
                 after:w-0 after:h-px after:bg-gold after:transition-all after:duration-500
                 hover:after:w-full"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="hidden lg:flex items-center gap-4">
      <a
        href="/contact"
        class="relative inline-flex items-center gap-2 px-6 py-2.5 text-sm uppercase tracking-[0.12em]
               font-body font-medium border border-charcoal/20 rounded-full text-charcoal
               overflow-hidden transition-colors duration-500 hover:text-ivory hover:border-gold
               group"
      >
        <span class="relative z-10">Get a Quote</span>
        <svg class="relative z-10 w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 14 14" stroke="currentColor" stroke-width="1.5">
          <path d="M1 7h12M8 2l5 5-5 5" />
        </svg>
        <span class="absolute inset-0 bg-gold scale-x-0 origin-left transition-transform duration-500 group-hover:scale-x-100"></span>
      </a>
    </div>

    <button
      class="lg:hidden flex flex-col gap-1.5 p-2 -mr-2"
      id="mobile-toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="block w-6 h-px bg-charcoal transition-all duration-300 origin-center" id="hamburger-top"></span>
      <span class="block w-6 h-px bg-charcoal transition-all duration-300" id="hamburger-mid"></span>
      <span class="block w-4 h-px bg-charcoal transition-all duration-300 origin-center" id="hamburger-bot"></span>
    </button>
  </div>

  <div
    class="fixed inset-0 bg-ivory/95 backdrop-blur-3xl z-40 flex flex-col items-center justify-center
           opacity-0 pointer-events-none transition-opacity duration-500"
    id="mobile-menu"
  >
    <nav class="flex flex-col items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="font-heading text-h2 text-charcoal hover:text-gold transition-colors duration-300"
        >
          {link.label}
        </a>
      ))}
    </nav>
    <div class="mt-12">
      <a
        href="/contact"
        class="inline-flex items-center gap-2 px-8 py-3 bg-gold text-ivory text-sm uppercase
               tracking-[0.15em] font-body font-medium rounded-full"
      >
        Get a Quote
      </a>
    </div>
  </div>
</header>

<script>
  function initHeader() {
    const header = document.getElementById('site-header');
    const toggle = document.getElementById('mobile-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const hamburgerTop = document.getElementById('hamburger-top');
    const hamburgerMid = document.getElementById('hamburger-mid');
    const hamburgerBot = document.getElementById('hamburger-bot');

    if (!header || !toggle || !mobileMenu) return;

    let lastScroll = 0;
    let isMenuOpen = false;

    window.addEventListener('scroll', () => {
      if (isMenuOpen) return;
      const currentScroll = window.scrollY;

      if (currentScroll > lastScroll && currentScroll > 200) {
        header.style.transform = 'translateY(-100%)';
      } else {
        header.style.transform = 'translateY(0)';
      }
      lastScroll = currentScroll;
    });

    toggle.addEventListener('click', () => {
      isMenuOpen = !isMenuOpen;
      toggle.setAttribute('aria-expanded', String(isMenuOpen));

      if (isMenuOpen) {
        mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
        mobileMenu.classList.add('opacity-100', 'pointer-events-auto');
        hamburgerTop?.classList.add('rotate-45', 'translate-y-[4px]');
        hamburgerMid?.classList.add('opacity-0');
        hamburgerBot?.classList.add('-rotate-45', '-translate-y-[4px]', 'w-6');
        document.body.style.overflow = 'hidden';
      } else {
        mobileMenu.classList.add('opacity-0', 'pointer-events-none');
        mobileMenu.classList.remove('opacity-100', 'pointer-events-auto');
        hamburgerTop?.classList.remove('rotate-45', 'translate-y-[4px]');
        hamburgerMid?.classList.remove('opacity-0');
        hamburgerBot?.classList.remove('-rotate-45', '-translate-y-[4px]', 'w-6');
        document.body.style.overflow = '';
      }
    });

    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        isMenuOpen = false;
        mobileMenu.classList.add('opacity-0', 'pointer-events-none');
        mobileMenu.classList.remove('opacity-100', 'pointer-events-auto');
        hamburgerTop?.classList.remove('rotate-45', 'translate-y-[4px]');
        hamburgerMid?.classList.remove('opacity-0');
        hamburgerBot?.classList.remove('-rotate-45', '-translate-y-[4px]', 'w-6');
        document.body.style.overflow = '';
      });
    });
  }

  document.addEventListener('astro:page-load', initHeader);
</script>
