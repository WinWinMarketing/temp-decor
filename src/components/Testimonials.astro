---
import TestimonialCarousel from './TestimonialCarousel.tsx';
---

<section class="py-20 lg:py-28 bg-ivory" id="testimonials">
  <div class="container">
    <div class="text-center mb-12 lg:mb-14">
      <p class="section-label mb-3 sm:mb-4" data-animate="fade-up">Testimonials</p>
      <h2 class="font-heading section-heading text-charcoal" data-animate="fade-up">
        Voices of Our Clients
      </h2>
    </div>
    <div data-animate="fade-up">
      <TestimonialCarousel client:visible />
    </div>
  </div>
</section>
