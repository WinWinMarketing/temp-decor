---
import ServiceCard from './ServiceCard.astro';

const services = [
  {
    title: 'Wedding Decor',
    description: 'Stunning arches, mandaps, ceremony backdrops, and reception styling — we craft wedding environments that leave lasting impressions.',
    image: 'https://images.unsplash.com/photo-1519225421980-715cb0215aed?w=600&q=80',
    href: '/services/wedding-decor',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>',
  },
  {
    title: 'Birthday & Party Decor',
    description: 'Themed birthday parties, first birthday setups, and milestone celebrations — custom props, signage, and decor that bring your vision to life.',
    image: 'https://images.unsplash.com/photo-1530103862676-de8c9debad1d?w=600&q=80',
    href: '/services/birthday-party-decor',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.871c1.355 0 2.697.056 4.024.166C17.155 8.51 18 9.473 18 10.608v2.513M15 8.25v-1.5m-6 1.5v-1.5m12 9.75l-1.5.75a3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0L3 16.5m15-3.379a48.474 48.474 0 00-6-.371c-2.032 0-4.034.126-6 .371m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.169c0 .621-.504 1.125-1.125 1.125H4.125A1.125 1.125 0 013 20.625v-5.17c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 016 13.12"/></svg>',
  },
  {
    title: 'Event Styling',
    description: 'Cultural celebrations, corporate events, and milestone occasions — styled with precision and creative flair.',
    image: 'https://images.unsplash.com/photo-1511795409834-ef04bbd61622?w=600&q=80',
    href: '/services/event-styling',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>',
  },
  {
    title: 'Balloon Decor',
    description: 'Eye-catching balloon garlands, arches, columns, and organic balloon installations that add colour and excitement to any celebration.',
    image: 'https://images.unsplash.com/photo-1527529482837-4698179dc6ce?w=600&q=80',
    href: '/services/balloon-decor',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M12 2C8.686 2 6 5.134 6 9c0 3.866 2.686 7 6 7s6-3.134 6-7c0-3.866-2.686-7-6-7zm0 14c-.55 0-1-.45-1-1h2c0 .55-.45 1-1 1zm-1 1h2v1c0 .55-.45 1-1 1s-1-.45-1-1v-1zm1 4c-.55 0-1-.45-1-1h2c0 .55-.45 1-1 1z"/></svg>',
  },
];
---

<section class="py-24 lg:py-32 bg-ivory" id="services-preview">
  <div class="container">
    <div class="text-center mb-16">
      <p class="section-label mb-4" data-animate="fade-up">What We Do</p>
      <h2 class="font-heading text-h1 text-charcoal" data-animate="fade-up">
        Our Decor Services
      </h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6" data-animate="stagger">
      {services.map((service) => (
        <ServiceCard {...service} />
      ))}
    </div>
  </div>
</section>
