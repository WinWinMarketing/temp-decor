---
const base = import.meta.env.BASE_URL;
---
<section class="py-24 lg:py-32 relative overflow-hidden" id="cta">
  <div class="absolute inset-0">
    <img
      src="https://images.unsplash.com/photo-1465495976277-4387d4b0b4c6?w=1920&q=80"
      alt="Outdoor wedding ceremony setting"
      class="w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-charcoal/75"></div>
  </div>

  <div class="container relative z-10 text-center">
    <p class="section-label text-gold-light mb-4" data-animate="fade-up">Ready to Begin?</p>
    <h2 class="font-heading text-h1 text-ivory mb-6 max-w-3xl mx-auto" data-animate="fade-up">
      Let's Create Something Beautiful Together
    </h2>
    <p class="text-lead text-ivory/70 max-w-xl mx-auto mb-10 leading-relaxed" data-animate="fade-up">
      Whether it's a dream wedding, a themed birthday party, or a stunning balloon installation —
      we're here to make your vision a breathtaking reality.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center" data-animate="fade-up">
      <a
        href={`${base}contact`}
        class="inline-flex items-center justify-center gap-2 px-8 py-3.5
               bg-gold text-ivory text-sm uppercase tracking-[0.15em] font-body font-medium
               rounded-sm transition-all duration-500 hover:bg-gold-light hover:shadow-lg group"
        data-magnetic
      >
        <span>Get a Free Quote</span>
        <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 14 14" stroke="currentColor" stroke-width="1.5">
          <path d="M1 7h12M8 2l5 5-5 5" />
        </svg>
      </a>
      <a
        href="tel:+16476714118"
        class="inline-flex items-center justify-center gap-2 px-8 py-3.5
               border border-ivory/40 text-ivory text-sm uppercase tracking-[0.15em] font-body font-medium
               rounded-sm transition-all duration-500 hover:bg-ivory/10"
        data-magnetic
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
        </svg>
        <span>+1 (647) 671-4118</span>
      </a>
    </div>
  </div>
</section>
