---
const phrases = [
  'Luxury Decor',
  'Timeless Design',
  'Your Vision, Our Craft',
  'Bespoke Elegance',
  'Curated Beauty',
  'Unforgettable Moments',
];
---

<section class="py-6 bg-cream overflow-hidden" aria-hidden="true">
  <div class="flex whitespace-nowrap" style="animation: marquee 30s linear infinite;">
    {[...phrases, ...phrases].map((phrase) => (
      <span class="inline-flex items-center gap-6 mx-6 font-heading text-h3 text-charcoal/20">
        {phrase}
        <svg class="w-3 h-3 text-gold/40" viewBox="0 0 16 16" fill="currentColor">
          <path d="M8 0L10 6L16 8L10 10L8 16L6 10L0 8L6 6Z"/>
        </svg>
      </span>
    ))}
  </div>
</section>
