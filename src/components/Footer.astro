---
const currentYear = new Date().getFullYear();

const navLinks = [
  { href: '/services', label: 'Decor Services' },
  { href: '/portfolio', label: 'Your Design' },
  { href: '/about', label: 'Our Company' },
  { href: '/contact', label: 'Contact Us' },
];

const services = [
  { href: '/services/wedding-decor', label: 'Wedding Decor' },
  { href: '/services/birthday-party-decor', label: 'Birthday & Party Decor' },
  { href: '/services/event-styling', label: 'Event Styling' },
  { href: '/services/balloon-decor', label: 'Balloon Decor' },
];
---

<footer class="bg-charcoal text-ivory/80 pt-20 pb-8">
  <div class="container">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 pb-16 border-b border-ivory/10">
      <div>
        <a href="/" class="inline-block mb-6">
          <img src="/temp-decor/logo.png" alt="Sai Decoration" class="h-14 w-auto" />
        </a>
        <p class="text-sm leading-relaxed text-ivory/50 max-w-xs">
          Premium wedding, birthday, and event decoration services. Transforming your vision into unforgettable celebrations.
        </p>
      </div>

      <div>
        <h4 class="font-body text-sm font-semibold uppercase tracking-[0.15em] text-ivory/70 mb-6">
          Navigate
        </h4>
        <ul class="space-y-3">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-ivory/50 hover:text-gold transition-colors duration-300">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-body text-sm font-semibold uppercase tracking-[0.15em] text-ivory/70 mb-6">
          Services
        </h4>
        <ul class="space-y-3">
          {services.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-ivory/50 hover:text-gold transition-colors duration-300">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-body text-sm font-semibold uppercase tracking-[0.15em] text-ivory/70 mb-6">
          Get in Touch
        </h4>
        <ul class="space-y-3 text-sm text-ivory/50">
          <li>
            <a href="tel:+14161234567" class="hover:text-gold transition-colors duration-300">
              +1 (416) 123-4567
            </a>
          </li>
          <li>
            <a href="mailto:hello@saidecoration.com" class="hover:text-gold transition-colors duration-300">
              hello@saidecoration.com
            </a>
          </li>
          <li class="text-ivory/40">Toronto, Ontario, Canada</li>
        </ul>
        <div class="flex gap-4 mt-6">
          <a href="https://www.instagram.com/sai_decoration" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-9 h-9 rounded-full border border-ivory/20 flex items-center justify-center hover:border-gold hover:text-gold transition-all duration-300" data-magnetic>
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="#" aria-label="Facebook" class="w-9 h-9 rounded-full border border-ivory/20 flex items-center justify-center hover:border-gold hover:text-gold transition-all duration-300" data-magnetic>
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" aria-label="Pinterest" class="w-9 h-9 rounded-full border border-ivory/20 flex items-center justify-center hover:border-gold hover:text-gold transition-all duration-300" data-magnetic>
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="flex flex-col md:flex-row items-center justify-between pt-8 gap-4">
      <p class="text-xs text-ivory/30">
        &copy; {currentYear} Sai Decoration. All rights reserved.
      </p>
      <button
        id="back-to-top"
        class="w-10 h-10 rounded-full border border-ivory/20 flex items-center justify-center
               hover:border-gold hover:-translate-y-1 transition-all duration-300 text-ivory/50 hover:text-gold"
        aria-label="Back to top"
        data-magnetic
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path d="M5 15l7-7 7 7" />
        </svg>
      </button>
      <p class="text-xs text-ivory/30">
        Experience by <a href="https://winwinmarketing.ca" class="text-gold/60 hover:text-gold transition-colors">WinWin Marketing</a>
      </p>
    </div>
  </div>
</footer>

<script>
  function initFooter() {
    const backToTop = document.getElementById('back-to-top');
    backToTop?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
  document.addEventListener('astro:page-load', initFooter);
</script>
