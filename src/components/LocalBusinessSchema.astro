---
import JsonLd from './JsonLd.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'EventPlanner',
  name: 'Sai Decoration Inc.',
  image: 'https://winwinmarketing.github.io/temp-decor/logo.png',
  url: 'https://winwinmarketing.github.io/temp-decor',
  telephone: '+14161234567',
  email: 'hello@saidecoration.com',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Toronto',
    addressRegion: 'ON',
    addressCountry: 'CA',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 43.6532,
    longitude: -79.3832,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '18:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Saturday',
      opens: '10:00',
      closes: '16:00',
    },
  ],
  priceRange: '$$$',
  sameAs: [
    'https://instagram.com/sai_decoration',
    'https://facebook.com/saidecoration',
    'https://pinterest.com/saidecoration',
  ],
  description: 'Premium wedding, birthday party, and event decoration services in Toronto. Balloon decor, themed party styling, and custom event design.',
  areaServed: {
    '@type': 'GeoCircle',
    geoMidpoint: {
      '@type': 'GeoCoordinates',
      latitude: 43.6532,
      longitude: -79.3832,
    },
    geoRadius: '100000',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Decoration Services',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Wedding Decor' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Birthday & Party Decor' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Event Styling' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Balloon Decor' } },
    ],
  },
};
---

<JsonLd data={schema} />
