---
const showcaseItems = [
  {
    image: 'https://images.unsplash.com/photo-1519167758481-83f550bb49b3?w=900&q=80',
    title: 'Luxury Reception Hall',
    label: 'Wedding Decor',
    description: 'Creating unforgettable wedding reception experiences with expertly designed decor that leaves clients overjoyed.',
  },
  {
    image: 'https://images.unsplash.com/photo-1530103862676-de8c9debad1d?w=900&q=80',
    title: 'Themed Birthday Magic',
    label: 'Birthday Party',
    description: 'Custom themed birthday setups with props, cutouts, signage, and coordinated decor that bring your child\'s favourite characters to life.',
  },
  {
    image: 'https://images.unsplash.com/photo-1527529482837-4698179dc6ce?w=900&q=80',
    title: 'Balloon Garland Backdrop',
    label: 'Balloon Decor',
    description: 'Stunning organic balloon installations and garland backdrops in custom colour schemes that transform any venue into a celebration.',
  },
  {
    image: 'https://images.unsplash.com/photo-1465495976277-4387d4b0b4c6?w=900&q=80',
    title: 'Beautiful Outdoor Ceremony',
    label: 'Wedding Decor',
    description: 'Celebrate amidst nature\'s beauty with a gorgeous outdoor wedding arch and decor that adds whimsy and romance to your special day.',
  },
  {
    image: 'https://images.unsplash.com/photo-1513151233558-d860c5398176?w=900&q=80',
    title: 'First Birthday Celebration',
    label: 'Birthday Party',
    description: 'Make your little one\'s first birthday unforgettable with adorable themed decor, balloon displays, and photo-worthy setups.',
  },
  {
    image: 'https://images.unsplash.com/photo-1511795409834-ef04bbd61622?w=900&q=80',
    title: 'Elegant Event Styling',
    label: 'Event Styling',
    description: 'Elevate your celebration with a stunning display of elegance, creating a breathtaking and unforgettable ambiance for your event.',
  },
  {
    image: 'https://images.unsplash.com/photo-1583939003579-730e3918a45a?w=900&q=80',
    title: 'Cultural Celebration Design',
    label: 'Cultural Events',
    description: 'Custom cultural celebration designs that honour traditions with stunning decor. Let us create a meaningful celebration that is truly unforgettable.',
  },
  {
    image: 'https://images.unsplash.com/photo-1586985289688-ca3cf47d3e6e?w=900&q=80',
    title: 'Balloon Arch Installations',
    label: 'Balloon Decor',
    description: 'Eye-catching balloon arches and columns that frame entrances, stages, and photo areas with vibrant colour and style.',
  },
  {
    image: 'https://images.unsplash.com/photo-1519225421980-715cb0215aed?w=900&q=80',
    title: 'Romantic Wedding Details',
    label: 'Wedding Decor',
    description: 'Every detail is meticulously crafted — from exquisite centrepieces to breathtaking lighting, creating an atmosphere of pure romance.',
  },
  {
    image: 'https://images.unsplash.com/photo-1464349095431-e9a21285b5f3?w=900&q=80',
    title: 'Milestone Party Decor',
    label: 'Party Decor',
    description: 'Celebrating milestones in style with custom props, themed backdrops, and coordinated decor that makes every moment picture-perfect.',
  },
];
const base = '/temp-decor';
---

<section class="py-16 lg:py-24 bg-ivory" id="decor-showcase">
  <div class="container">
    <div class="text-center mb-16">
      <p class="section-label mb-4" data-animate="fade-up">Our Designs</p>
      <h2 class="font-heading text-h1 text-charcoal mb-4" data-animate="fade-up">
        Moments We Love
      </h2>
      <p class="text-lead text-warm-gray max-w-2xl mx-auto" data-animate="fade-up">
        Every project tells a unique story. Browse our collection of designs
        that transform ordinary spaces into extraordinary experiences.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
      {showcaseItems.map((item) => (
        <a
          href={`${base}/portfolio`}
          class="group block overflow-hidden rounded-2xl bg-cream"
          data-animate="fade-up"
        >
          <div class="aspect-[4/3] overflow-hidden">
            <img
              src={item.image}
              alt={item.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
          </div>
          <div class="p-6 lg:p-8">
            <span class="text-xs uppercase tracking-[0.2em] text-gold font-body font-semibold">
              {item.label}
            </span>
            <h3 class="font-heading text-h3 text-charcoal mt-2 group-hover:text-gold transition-colors duration-300">
              {item.title}
            </h3>
            <p class="text-sm text-warm-gray leading-relaxed mt-2">
              {item.description}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
