---
const slides = [
  {
    image: 'https://images.unsplash.com/photo-1519167758481-83f550bb49b3?w=1920&q=80',
    title: 'Luxury Wedding Decor',
    subtitle: 'Bringing your dream celebration to life with luxurious, timeless décor and stunning setups.',
  },
  {
    image: 'https://images.unsplash.com/photo-1530103862676-de8c9debad1d?w=1920&q=80',
    title: 'Unforgettable Birthday Parties',
    subtitle: 'Themed birthday parties and milestone celebrations with custom props, signage, and decor.',
  },
  {
    image: 'https://images.unsplash.com/photo-1527529482837-4698179dc6ce?w=1920&q=80',
    title: 'Stunning Balloon Installations',
    subtitle: 'Balloon garlands, organic arches, and custom installations that transform any venue.',
  },
  {
    image: 'https://images.unsplash.com/photo-1511795409834-ef04bbd61622?w=1920&q=80',
    title: 'Exquisite Event Styling',
    subtitle: 'Corporate events, cultural celebrations, and special occasions styled to perfection.',
  },
];
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden" id="hero">
  <div class="absolute inset-0" id="hero-slides">
    {slides.map((slide, i) => (
      <div
        class:list={[
          'absolute inset-0 transition-opacity duration-1000',
          i === 0 ? 'opacity-100' : 'opacity-0',
        ]}
        data-slide={i}
      >
        <img
          src={slide.image}
          alt={slide.title}
          class="w-full h-full object-cover"
          loading={i === 0 ? 'eager' : 'lazy'}
        />
      </div>
    ))}
    <div class="absolute inset-0 bg-gradient-to-b from-charcoal/50 via-charcoal/30 to-charcoal/60"></div>
  </div>

  <div class="relative z-10 text-center px-5 max-w-4xl">
    <p class="section-label text-gold-light mb-4" data-animate="fade-up">
      One-Stop Wedding & Event Decoration
    </p>
    <h1
      class="font-heading text-display text-ivory leading-[1.05] mb-6"
      id="hero-title"
      data-animate="fade-up"
    >
      {slides[0].title}
    </h1>
    <p
      class="font-body text-lead text-ivory/80 max-w-2xl mx-auto leading-relaxed mb-10"
      id="hero-subtitle"
      data-animate="fade-up"
    >
      {slides[0].subtitle}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center" data-animate="fade-up">
      <a
        href="/portfolio"
        class="relative inline-flex items-center justify-center gap-2 px-8 py-3.5
               bg-gold text-ivory text-sm uppercase tracking-[0.15em] font-body font-medium
               rounded-sm overflow-hidden transition-all duration-500 hover:bg-gold-light hover:shadow-lg group"
      >
        <span class="relative z-10">Explore Our Work</span>
        <svg class="relative z-10 w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 14 14" stroke="currentColor" stroke-width="1.5">
          <path d="M1 7h12M8 2l5 5-5 5" />
        </svg>
      </a>
      <a
        href="/contact"
        class="inline-flex items-center justify-center gap-2 px-8 py-3.5
               border border-ivory/40 text-ivory text-sm uppercase tracking-[0.15em] font-body font-medium
               rounded-sm transition-all duration-500 hover:bg-ivory/10 hover:border-ivory"
      >
        Get a Quote
      </a>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-ivory/50">
    <span class="text-[0.65rem] uppercase tracking-[0.3em] font-body">Scroll</span>
    <div class="w-px h-8 bg-ivory/30" style="animation: scrollPulse 2s ease-in-out infinite;"></div>
  </div>
</section>

<script>
  function initHeroSlider() {
    const slides = document.querySelectorAll('[data-slide]');
    const heroTitle = document.getElementById('hero-title');
    const heroSubtitle = document.getElementById('hero-subtitle');
    if (slides.length < 2) return;

    const slideData = [
      { title: 'Luxury Wedding Decor', subtitle: 'Bringing your dream celebration to life with luxurious, timeless décor and stunning setups.' },
      { title: 'Unforgettable Birthday Parties', subtitle: 'Themed birthday parties and milestone celebrations with custom props, signage, and decor.' },
      { title: 'Stunning Balloon Installations', subtitle: 'Balloon garlands, organic arches, and custom installations that transform any venue.' },
      { title: 'Exquisite Event Styling', subtitle: 'Corporate events, cultural celebrations, and special occasions styled to perfection.' },
    ];

    let currentSlide = 0;
    setInterval(() => {
      const prevSlide = currentSlide;
      currentSlide = (currentSlide + 1) % slides.length;
      slides[prevSlide].classList.remove('opacity-100');
      slides[prevSlide].classList.add('opacity-0');
      slides[currentSlide].classList.remove('opacity-0');
      slides[currentSlide].classList.add('opacity-100');
      if (heroTitle) heroTitle.textContent = slideData[currentSlide].title;
      if (heroSubtitle) heroSubtitle.textContent = slideData[currentSlide].subtitle;
    }, 5000);
  }

  document.addEventListener('astro:page-load', initHeroSlider);
</script>
